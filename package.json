    "@schedule-x/vue": "^4.1.0",
    "ag-grid-community": "^35.3.1",
    "ag-grid-vue3": "^35.3.1",
    "ical.js": "^2.2.1",
    "pinia": "^3.0.4",
    "preact": "^10.29.2",
    "temporal-polyfill": "^1.0.1",
    "vue": "^3.5.38",
    "vue-grid-layout-v3": "^3.1.2",
    "vue-router": "^5.1.0",
    "vue3-openlayers": "^12.2.2"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
